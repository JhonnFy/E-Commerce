@model UserVM;

@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* TODO: mantener estilos originales */
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #ffffff, #e5e5e5);
            font-family: Arial, Helvetica, sans-serif;
            overflow: hidden;
        }

        .background-text {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-18deg);
            font-size: 12rem;
            font-weight: 900;
            letter-spacing: 8px;
            z-index: 0;
            user-select: none;
            pointer-events: none;
            color: #053345;
            opacity: 0.08;
        }

        .login-container {
            position: relative;
            z-index: 10;
            width: 480px;
            padding: 40px;
        }

            .login-container h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
                letter-spacing: 2px;
                color: #053345;
            }

        label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #053345;
            display: block;
            margin-bottom: 6px;
        }

        .password-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .toggle-password {
            cursor: pointer;
            font-size: 0.9rem;
            color: #053345;
            transition: 0.2s;
        }

            .toggle-password:hover {
                opacity: 0.7;
            }

        .transparent-input {
            width: 100%;
            padding: 10px;
            margin-bottom: 20px;
            border: none;
            border-bottom: 1px solid rgba(5,51,69,0.4);
            background: transparent;
            font-size: 0.9rem;
            transition: 0.3s;
            color: #053345;
            line-height: 1.3;
        }

            .transparent-input:focus {
                outline: none;
                border-bottom: 1px solid #053345;
            }

        .btn-login, .btn-register {
            display: block;
            width: 100%;
            padding: 10px;
            font-size: 0.9rem;
            line-height: 1.3;
            text-align: center;
            border-radius: 5px;
            transition: 0.3s;
            margin-bottom: 10px;
        }

        .btn-login {
            background: #053345;
            color: white;
            border: none;
        }

            .btn-login:hover {
                background: #042733;
            }

        .btn-register {
            background: transparent;
            border: 1px solid #053345;
            color: #053345;
            text-decoration: none;
        }

            .btn-register:hover {
                background: #053345;
                color: white;
            }

        .swal2-title {
            font-weight: bold !important;
            letter-spacing: 2px !important;
            text-align: center !important;
            font-family: inherit !important;
            font-size: 1.5em !important;
        }

        .swal2-styled.swal2-confirm {
            background-color: #053345 !important;
            border: 1px solid #053345 !important;
            box-shadow: none !important;
        }

        /*Logo*/
        .brand-logo {
            position: absolute;
            top: 60px;
            left: 60px;
            height: 70px;
            z-index: 20;
        }

    </style>
</head>
<body>

    <img src="~/logos/LogoV2.png" class="brand-logo" />

    <div class="background-text">
        E-COMMERCE
    </div>

    <div class="login-container">
        <h2>REGISTER</h2>

        <form id="registerForm" action="/Account/Register" method="post">

            <label>Full Name</label>
            <input asp-for="FullName" type="text" class="transparent-input" id="FullName" autocomplete="off" />

            <label>Email</label>
            <input asp-for="Email" type="email" class="transparent-input" id="Email" autocomplete="off" />

            <!-- PASSWORD -->
            <label class="password-label">
                Password
                <i class="fa-regular fa-eye toggle-password"
                   onclick="togglePassword(this, 'passwordInput')"></i>
            </label>
            <input asp-for="Password" type="password" id="passwordInput" class="transparent-input" autocomplete="off" />

            <!-- REPEAT PASSWORD -->
            <label class="password-label">
                Repeat Password
                <i class="fa-regular fa-eye toggle-password"
                   onclick="togglePassword(this, 'repeatPasswordInput')"></i>
            </label>
            <input asp-for="RepeatPassword" type="password" id="repeatPasswordInput" class="transparent-input" autocomplete="off" />

            <input type="hidden" name="Type" value="Client" />

            <button class="btn-login" type="submit">Register</button>
            <a href="/Account/Login" class="btn-register">Back</a>

        </form>
    </div>

    <script>
        function togglePassword(icon, inputId) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        // VALIDACIÓN DE CAMPOS VACÍOS
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            const fullName = document.getElementById('FullName').value.trim();
            const email = document.getElementById('Email').value.trim();
            const password = document.getElementById('passwordInput').value.trim();
            const repeatPassword = document.getElementById('repeatPasswordInput').value.trim();

                    if (!fullName || !email || !password || !repeatPassword) 
                    {
                        e.preventDefault();
                        Swal.fire({
                        icon: 'warning',
                        text: 'Todos Los Campos Son Obligatorios'
                        }).then(() => {
                        document.getElementById("registerForm").reset();
                        });
                    }
        });
    </script>

    @* ALERTAS DESDE EL CONTROLADOR *@
    @if (ViewBag.message != null)
    {
        <script>
            Swal.fire({
                icon: '@ViewBag.Class',
                title: '@ViewBag.message'
            }).then((result) => {
                if (result.isConfirmed && '@ViewBag.Class' === 'success') {
                    window.location.href = '/Account/Login';
                }
            });
        </script>
    }



</body>
</html>

