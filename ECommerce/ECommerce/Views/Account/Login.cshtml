@model LoginVM;

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #ffffff, #e5e5e5);
            font-family: Arial, Helvetica, sans-serif;
            overflow: hidden;
        }

        .background-text {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-18deg);
            font-size: 12rem;
            font-weight: 900;
            letter-spacing: 8px;
            z-index: 0;
            user-select: none;
            pointer-events: none;
            color: #053345;
            opacity: 0.08;
        }

        .login-container {
            position: relative;
            z-index: 10;
            width: 480px;
            padding: 40px;
        }

            .login-container h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
                letter-spacing: 2px;
                color: #053345;
            }

        label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #053345;
            display: block;
            margin-bottom: 6px;
        }

        /* Label especial para password */
        .password-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .toggle-password {
            cursor: pointer;
            font-size: 0.9rem;
            color: #053345;
            transition: 0.2s;
        }

            .toggle-password:hover {
                opacity: 0.7;
            }

        .transparent-input {
            width: 100%;
            padding: 10px;
            margin-bottom: 25px;
            border: none;
            border-bottom: 1px solid rgba(5,51,69,0.4);
            background: transparent;
            font-size: 0.9rem;
            transition: 0.3s;
            color: #053345;
        }

            .transparent-input:focus {
                outline: none;
                border-bottom: 1px solid #053345;
            }

        .btn-login,
        .btn-register {
            display: block;
            width: 100%;
            padding: 14px 10px;
            font-size: 1rem;
            text-align: center;
            border-radius: 5px;
            transition: 0.3s;
            margin-bottom: 10px;
            text-decoration: none;
        }

        .btn-login {
            background: #053345;
            color: white;
            border: none;
        }

            .btn-login:hover {
                background: #042733;
            }

        .btn-register {
            background: transparent;
            border: 1px solid #053345;
            color: #053345;
        }

            .btn-register:hover {
                background: #053345;
                color: white;
            }

        .swal2-title {
            font-weight: bold !important;
            letter-spacing: 2px !important;
            text-align: center !important;
            font-family: inherit !important;
            font-size: 1.5em !important;
        }

        .swal2-styled.swal2-confirm {
            background-color: #053345 !important;
            border: 1px solid #053345 !important;
            box-shadow: none !important;
        }

    </style>

</head>
<body>

    <div class="background-text">
        E-COMMERCE
    </div>

    <div class="login-container">
        <h2>LOGIN</h2>

        <form action="/Account/Login" method="post">

            <label>Email</label>
            <input asp-for="Email" type="email" class="transparent-input" autocomplete="off" />

            <!-- LABEL con ojito al lado -->
            <label class="password-label">
                Password
                <i class="fa-regular fa-eye toggle-password"
                   onclick="togglePassword(this)"></i>
            </label>

            <input asp-for="Password"
                   type="password"
                   class="transparent-input"
                   id="passwordInput"
                   autocomplete="off" />

            <button type="submit" class="btn-login">Login</button>
            <a href="/Account/Register" class="btn-register">Register</a>

        </form>
    </div>

    <script>
        function togglePassword(icon) {
            const input = document.getElementById("passwordInput");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }
    </script>


    @if (ViewBag.message != null)
    {
        <script>
            Swal.fire({
                icon: '@ViewBag.Class',
                title: '@ViewBag.message'
            });
        </script>
    }


</body>
</html>

